rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar si el usuario es el dueño de la barbería
    function isOwner(barberiaId) {
      return request.auth != null && 
        get(/databases/$(database)/documents/barberias/$(barberiaId)).data.ownerId == request.auth.uid;
    }

    // Reglas para barberías
    match /barberias/{barberiaId} {
      allow read: if true; // Público puede ver datos de la barbería para booking
      allow create: if request.auth != null; // Usuarios logueados pueden crear su barbería
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    // Reglas para usuarios
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Reglas para colecciones multi-tenant (turnos, servicios, clientes)
    match /turnos/{docId} {
      allow read, write: if isOwner(request.resource.data.barberiaId || resource.data.barberiaId);
      allow create: if true; // Público puede crear turnos (booking)
    }

    match /servicios/{docId} {
      allow read: if true; // Público puede ver servicios para booking
      allow write: if isOwner(request.resource.data.barberiaId || resource.data.barberiaId);
    }

    match /clientes/{docId} {
      allow create: if true; // Público puede registrarse como cliente al reservar
      allow read, write: if isOwner(request.resource.data.barberiaId || resource.data.barberiaId);
    }
  }
}
