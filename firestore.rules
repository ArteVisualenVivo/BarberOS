rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function currentUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function currentUserData() {
      return currentUserDoc().data;
    }

    function isOwner(barberiaId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/barberias/$(barberiaId)).data.ownerId == request.auth.uid;
    }

    match /barberias/{barberiaId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.resource.data.ownerId == request.auth.uid &&
        currentUserDoc().exists() &&
        !(currentUserData().barberiaId is string) &&
        currentUserData().trialConsumed != true;
      allow update, delete: if request.auth != null && resource.data.ownerId == request.auth.uid;
    }

    match /users/{userId} {
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.role == "owner";
      allow read: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.uid == resource.data.uid &&
        request.resource.data.role == resource.data.role &&
        (
          !(resource.data.barberiaId is string) ||
          request.resource.data.barberiaId == resource.data.barberiaId
        ) &&
        (
          resource.data.trialConsumed != true ||
          request.resource.data.trialConsumed == true
        );
      allow delete: if request.auth != null && request.auth.uid == userId;
    }

    function isLicenseManager() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "owner"
      );
    }

    match /licenses/{licenseId} {
      allow read: if isLicenseManager();
      allow create, update, delete: if isLicenseManager();
    }

    match /turnos/{docId} {
      allow read, write: if isOwner(request.resource.data.barberiaId || resource.data.barberiaId);
      allow create: if true;
    }

    match /servicios/{docId} {
      allow read: if true;
      allow write: if isOwner(request.resource.data.barberiaId || resource.data.barberiaId);
    }

    match /clientes/{docId} {
      allow create: if true;
      allow read, write: if isOwner(request.resource.data.barberiaId || resource.data.barberiaId);
    }
  }
}
